# Токен бота от @BotFather
DEBT_BOT_TOKEN=

# Белый список: Telegram ID через запятую (узнать: @userinfobot)
DEBT_BOT_ALLOWED_IDS=

# Прокси (если api.telegram.org блокируется): socks5://host:port или socks5://user:pass@host:port
# DEBT_BOT_PROXY=socks5://127.0.0.1:1080

# CoinMarketCap API key (получить: https://pro.coinmarketcap.com/)
# DEBT_BOT_CMC_API_KEY=your-api-key

# Ручной курс (fallback): DEBT_BOT_RATE=83.5

# Docker: путь к БД (по умолчанию /app/data/debt.db)
# DEBT_BOT_DB_PATH=/app/data/debt.db
